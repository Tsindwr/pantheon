---
const sampleNumbers =
  "177.5, 250, 189, 50, 1060, 96, 453";
const sampleTarget = "1726.5";
---

<main class="wrap">
  <h1>Combination Sum Finder</h1>
  <p>Find every combination from a number list that adds up to your target.</p>

  <form id="combo-form" class="panel">
    <label for="numbers">Numbers (comma separated)</label>
    <textarea id="numbers" rows="5">{sampleNumbers}</textarea>

    <label for="target">Target</label>
    <input id="target" type="text" value={sampleTarget} />

    <button type="submit">Find Combinations</button>
  </form>

  <section class="panel">
    <h2>Results</h2>
    <p id="meta">Submit to calculate.</p>
    <ol id="results"></ol>
  </section>
</main>

<script lang="ts">
  const form = document.getElementById("combo-form");
  const numbersInput = document.getElementById("numbers");
  const targetInput = document.getElementById("target");
  const meta = document.getElementById("meta");
  const results = document.getElementById("results");

  if (
    !(form instanceof HTMLFormElement) ||
    !(numbersInput instanceof HTMLTextAreaElement) ||
    !(targetInput instanceof HTMLInputElement) ||
    !(meta instanceof HTMLParagraphElement) ||
    !(results instanceof HTMLOListElement)
  ) {
    throw new Error("Expected form elements were not found in the page.");
  }

  const EPSILON = 0.000001;

  function toCents(value) {
    return Math.round(value * 100);
  }

  function parseNumbers(raw) {
    return raw
      .split(",")
      .map((part) => part.trim())
      .filter(Boolean)
      .map(Number)
      .filter((value) => Number.isFinite(value));
  }

  // Returns all combinations where each input number is used at most once.
  function findCombinations(numbers, target) {
    const sorted = [...numbers].sort((a, b) => a - b);
    const targetCents = toCents(target);
    const cents = sorted.map(toCents);
    const combos = [];
    const path = [];

    function backtrack(startIndex, runningSum) {
      if (runningSum === targetCents) {
        combos.push([...path]);
        return;
      }

      if (runningSum > targetCents) return;

      for (let i = startIndex; i < cents.length; i += 1) {
        if (i > startIndex && cents[i] === cents[i - 1]) continue;

        const nextSum = runningSum + cents[i];
        if (nextSum > targetCents) break;

        path.push(sorted[i]);
        backtrack(i + 1, nextSum);
        path.pop();
      }
    }

    backtrack(0, 0);
    return combos;
  }

  function compareCombinations(a, b) {
    if (a.length !== b.length) return a.length - b.length;
    for (let i = 0; i < a.length; i += 1) {
      if (a[i] !== b[i]) return a[i] - b[i];
    }
    return 0;
  }

  function fmt(value) {
    if (Math.abs(value - Math.round(value)) < EPSILON) return String(Math.round(value));
    return value.toFixed(2);
  }

  function renderCombinations(combos) {
    results.innerHTML = "";
    combos.forEach((combo) => {
      const li = document.createElement("li");
      li.textContent = combo.map(fmt).join(" + ");
      results.appendChild(li);
    });
  }

  form.addEventListener("submit", (event) => {
    event.preventDefault();

    const numbers = parseNumbers(numbersInput.value);
    const target = Number(targetInput.value.trim());

    if (!numbers.length || !Number.isFinite(target)) {
      meta.textContent = "Enter valid numbers and a valid target.";
      results.innerHTML = "";
      return;
    }

    const combos = findCombinations(numbers, target).sort(compareCombinations);
    meta.textContent = `Found ${combos.length} combination${combos.length === 1 ? "" : "s"}.`;
    renderCombinations(combos);
  });
</script>

<style>
  :root {
    --bg: #f7f8fb;
    --panel: #ffffff;
    --text: #1f2a37;
    --muted: #5c6774;
    --accent: #126ab2;
    --border: #d9e2ec;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    color: var(--text);
    background: radial-gradient(circle at top left, #e8f1ff 0%, var(--bg) 45%);
  }

  .wrap {
    max-width: 820px;
    margin: 2rem auto;
    padding: 0 1rem 2rem;
  }

  h1 {
    margin-bottom: 0.4rem;
  }

  p {
    color: var(--muted);
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    margin-top: 1rem;
    box-shadow: 0 8px 20px rgba(17, 24, 39, 0.04);
  }

  form {
    display: grid;
    gap: 0.7rem;
  }

  label {
    font-weight: 600;
  }

  textarea,
  input {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 1rem;
  }

  button {
    width: fit-content;
    border: none;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    padding: 0.6rem 1rem;
    font-weight: 600;
    cursor: pointer;
  }

  button:hover {
    filter: brightness(1.05);
  }

  #results {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
  }

  #results li {
    padding: 0.2rem 0;
    word-break: break-word;
  }

  @media (max-width: 640px) {
    .wrap {
      margin-top: 1rem;
    }
  }
</style>
