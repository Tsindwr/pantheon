---
import SunderSheetDemo from "../demo/SunderSheetDemo";
import "../styles/sunder-theme.css";
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sunder Character Sheet Demo</title>

    <style>
        :root {
            color-scheme: dark;
            --page-bg: radial-gradient(circle at top, #1f3550 0%, #0c1420 42%, #070b11 100%);
            --card-bg: rgba(10, 16, 24, 0.88);
            --card-border: rgba(242, 213, 144, 0.45);
            --text-main: #f6f0dd;
            --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            min-height: 100%;
        }

        body {
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
                sans-serif;
            background: var(--page-bg);
            color: var(--text-main);
        }
    </style>
</head>

<body>
    <SunderSheetDemo client:load />
</body>
</html>